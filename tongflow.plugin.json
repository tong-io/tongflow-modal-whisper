{
    "plugin": {
        "name": "Whisper",
        "description": "Speech recognition with OpenAI Whisper (with segment timestamps).",
        "icon": "/plugins/tongflow-modal-whisper.svg"
    },
    "env": [
        {
            "key": "MODAL_TOKEN_ID",
            "required": true,
            "description": "Modal token id",
            "url": "https://modal.com/settings/tokens"
        },
        {
            "key": "MODAL_TOKEN_SECRET",
            "required": true,
            "description": "Modal token secret (paired with MODAL_TOKEN_ID)"
        },
        {
            "key": "TONGFLOW_MODAL_CALL_TIMEOUT_S",
            "default": "2400",
            "description": "Max seconds to wait for a Modal call"
        },
        {
            "key": "WHISPER_MODEL",
            "default": "base",
            "description": "Whisper size — tiny / base / small / medium / large"
        }
    ]
}
